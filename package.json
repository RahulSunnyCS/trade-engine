{
  "name": "trade-engine",
  "version": "0.1.0",
  "description": "Adaptive multi-personality paper trading framework for NSE/BSE weekly options",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "backtest": "ts-node src/backtesting/run.ts",
    "ingest:mock": "ts-node src/data/ingest.ts --provider=mock",
    "ingest:fyers": "ts-node src/data/ingest.ts --provider=fyers",
    "lint": "eslint src --ext .ts",
    "db:migrate": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts"]
  }
}
