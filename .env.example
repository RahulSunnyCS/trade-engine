# ============================================================
# TRADE ENGINE — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# Rotate all secrets immediately if accidentally exposed.
# ============================================================

# ---- Application ----------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info                   # debug | info | warn | error

# ---- Fyers API (Broker + Market Data) -------------------
# Obtain from https://myapi.fyers.in/dashboard
FYERS_APP_ID=
FYERS_SECRET_KEY=
# Access token is short-lived (1 day). Refreshed via OAuth2 flow.
# After first auth, the app stores it; set manually for local dev.
FYERS_ACCESS_TOKEN=
FYERS_REDIRECT_URI=http://localhost:3000/auth/fyers/callback
FYERS_PAPER_TRADING=true         # true = paper mode, false = live

# ---- PostgreSQL + TimescaleDB ---------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trade_engine
POSTGRES_USER=trade_engine
POSTGRES_PASSWORD=
# Constructed URL used by Drizzle ORM and the app
DATABASE_URL=postgresql://trade_engine:REPLACE_PASSWORD@localhost:5432/trade_engine

# Production: Timescale Cloud free tier
# DATABASE_URL=postgresql://tsdbadmin:REPLACE@<host>.tsdb.cloud.timescale.com:PORT/trade_engine?sslmode=require

# ---- Redis ----------------------------------------------
REDIS_URL=redis://localhost:6379
# Set only if Redis is password-protected
REDIS_PASSWORD=

# ---- Drizzle ORM ----------------------------------------
# Used by drizzle-kit for migration commands
# Defaults to DATABASE_URL — override only if migrations use a different DB user
DRIZZLE_DATABASE_URL=

# ---- Telegram Alerts ------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: secondary alert channel (e.g. stop-loss alerts)
TELEGRAM_ALERT_CHAT_ID=

# ---- Monitoring -----------------------------------------
SENTRY_DSN=
# Optional: Grafana Cloud (free tier) Prometheus remote-write
GRAFANA_CLOUD_URL=
GRAFANA_CLOUD_USER=
GRAFANA_CLOUD_API_KEY=

# ---- Security -------------------------------------------
# Random 32-byte hex string. Generate with: openssl rand -hex 32
SESSION_SECRET=
JWT_SECRET=
# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173

# ---- Feature Flags --------------------------------------
ENABLE_LIVE_TRADING=false        # Safety gate — never enable in dev
ENABLE_TELEGRAM_ALERTS=false
ENABLE_RETROSPECTION=false       # Disable outside market hours in dev

# ---- Data Provider --------------------------------------
# 'fyers' | 'mock'  — use 'mock' until Fyers credentials are available
DATA_PROVIDER=mock

# ---- Backtesting ----------------------------------------
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_UNDERLYING=NIFTY,BANKNIFTY
BACKTEST_STARTING_CAPITAL=100000
